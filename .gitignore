# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Brand design sources (kept locally; app uses the exported PNG/SVG assets)
assets/*.ai
assets/*.eps
assets/*.pdf

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Google Play service-account key for `eas submit --platform android` — secret,
# never commit. Download from Play Console and save at the repo root.
google-play-service-account.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Supabase CLI cache
supabase/.temp/

# Microsoft Word / Excel lock files (auto-created while a doc is open)
~$*

# Business plan drafts — kept local-only, not version-controlled
Business Plan *.md

